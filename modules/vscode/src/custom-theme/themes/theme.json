{
    "name": "Custom Theme",
    /* User Interface
    --------------------------------------------------------------------------*/
    "colors": {
        /* Base */
        "focusBorder": "#1a3b83",
        "foreground": "#e5ccbc",
        "disabledForeground": "#a6887c",
        "widget.border": "#142656",
        "selection.background": "#255cbd40",
        "description.foreground": "#ff00ff",
        /* Title bar */
        "titleBar.activeBackground": "#142656",
        /* Activity bar */
        "activityBar.background": "#142656",
        "activityBar.foreground": "#e5ccbc",
        "activityBarBadge.background": "#3074d7",
        /* Status bar */
        "statusBar.background": "#142656",
        /* Side bar */
        "sideBar.background": "#121f47",
        "sideBar.foreground": "#e5ccbc",
        "sideBarTitle.foreground": "#ffefdf",
        "sideBarTitle.background": "#121f47",
        "sideBarSectionHeader.background": "#142656",
        "sideBarSectionHeader.foreground": "#ffefdf",
        /* List (affects side bar) */
        "list.activeSelectionBackground": "#1a3b83",
        "list.activeSelectionForeground": "#ffefdf",
        "list.inactiveSelectionBackground": "#162d65",
        "list.inactiveSelectionForeground": "#e5ccbc",
        "list.highlightForeground": "#ffe555",
        "list.hoverBackground": "#473336",
        /* Editor groups */
        "editorGroup.border": "#121f47",
        "editorGroup.emptyBackground": "#121f47",
        "editorGroupHeader.tabsBackground": "#121f47",
        "editorGroupHeader.tabsBorder": "#142656",
        /* Tabs */
        "tab.activeBackground": "#1a3b83",
        "tab.activeForeground": "#ffefdf",
        "tab.inactiveBackground": "#142656",
        "tab.inactiveForeground": "#d4b5a4",
        "tab.border": "#121f47",
        /* Breadcrumb */
        "breadcrumb.background": "#142656",
        "breadcrumb.foreground": "#d4b5a4",
        "breadcrumb.focusForeground": "#e5ccbc",
        "breadcrumb.activeSelectionForeground": "#ffefdf",
        "breadcrumbPicker.background": "#162d65",
        /* Panel (e.g. integrated terminal) */
        "panel.background": "#142656",
        "panel.border": "#162d65",
        /* Dropdown widget */
        "dropdown.background": "#162d65",
        "dropdown.listBackground": "#162d65",
        "dropdown.border": "#142656",
        "dropdown.foreground": "#e5ccbc",
        /* Input widget */
        "input.background": "#121f47",
        "input.foreground": "#e5ccbc",
        "input.border": "#162d65",
        "input.placeholderForeground": "#b9998a",
        "inputOption.activeBackground": "#255cbd80",
        "inputOption.activeForeground": "#ffefdf",
        "inputOption.activeBorder": "#255cbd",
        "inputOption.hoverBackground": "#1a3b8380",
        "inputValidation.errorBackground": "#5a0000",
        "inputValidation.errorForeground": "#ff443e",
        "inputValidation.errorBorder": "#ff443e",
        "inputValidation.warningBackground": "#9b4d00",
        "inputValidation.warningForeground": "#ffe555",
        "inputValidation.warningBorder": "#ffe555",
        "inputValidation.infoBackground": "#262e3f",
        "inputValidation.infoForeground": "#dfefff",
        "inputValidation.infoBorder": "#dfefff",
        /* Quick input widget (e.g. command palette) */
        "quickInput.background": "#162d65",
        "quickInput.foreground": "#e5ccbc",
        /* Buttons */
        "button.background": "#1a3b83",
        "button.foreground": "#ffefdf",
        "button.hoverBackground": "#255cbd",
        /* Text */
        "textLink.activeForeground": "#ffe555",
        "textLink.foreground": "#4099ff",
        /* Terminal */
        "terminal.background": "#01080f",
        "terminal.foreground": "#ddc1b0",
        "terminal.ansiBlack": "#01080f",
        "terminal.ansiRed": "#d30000",
        "terminal.ansiGreen": "#3cba3e",
        "terminal.ansiYellow": "#ffa321",
        "terminal.ansiBlue": "#2a68ca",
        "terminal.ansiMagenta": "#b50052",
        "terminal.ansiCyan": "#0b9684",
        "terminal.ansiWhite": "#ddc1b0",
        "terminal.ansiBrightBlack": "#414b60",
        "terminal.ansiBrightRed": "#ff443e",
        "terminal.ansiBrightGreen": "#7ce35b",
        "terminal.ansiBrightYellow": "#ffe555",
        "terminal.ansiBrightBlue": "#4099ff",
        "terminal.ansiBrightMagenta": "#ea3e8f",
        "terminal.ansiBrightCyan": "#3fd5b9",
        "terminal.ansiBrightWhite": "#eed8c7",
        /* Editor */
        "editor.background": "#01080f",
        "editor.foreground": "#ddc1b0",
        /* Editor cursor */
        "editorCursor.background": "#0e1522",
        "editorCursor.foreground": "#ffefdf",
        "editor.lineHighlightBackground": "#121f47",
        /* Editor word highlighting */
        "editor.wordHighlightBackground": "#142656",
        /* Editor selection highlighting */
        "editor.selectionBackground": "#255cbd60",
        /* NOTE: This setting is not working.
            see: https://github.com/microsoft/vscode/issues/36490 */
        "editor.selectionForeground": "#ff00ff",
        "editor.inactiveSelectionBackground": "#255cbd60",
        "editor.selectionHighlightBackground": "#255cbd60",
        "editor.selectionHighlightBorder": "#255cbd",
        /* Editor find highlighting */
        "editor.findMatchBackground": "#e3207b",
        "editor.findMatchForeground": "#0e1522",
        "editor.findMatchHighlightBackground": "#1e712d",
        "editor.findMatchHighlightForeground": "#0e1522",
        "editor.rangeHighlightBackground": "#e3207b40",
        /* Editor diagnostics */
        "editorError.foreground": "#ff2220",
        "editorWarning.foreground": "#ffdd3f",
        "editorInfo.foreground": "#d4b5a4",
        "editorHint.foreground": "#ffb23b",
        /* Editor bracket matching */
        "editorBracketMatch.background": "#142656",
        "editorBracketMatch.border": "#1a3b83",
        /* Editor guttter & line numbers */
        "editorGutter.background": "#01080f",
        "editorGutter.addedBackground": "#2d9536",
        "editorGutter.modifiedBackground": "#9b4d00",
        "editorGutter.deletedBackground": "#ab0000",
        "editorLineNumber.foreground": "#1a3b83",
        "editorLineNumber.activeForeground": "#3074d7",
        /* Editor ruler */
        "editorRuler.foreground": "#141b29",
        /* Editor indentation guides */
        "editorIndentGuide.background": "#141b29",
        "editorIndentGuide.activeBackground": "#1e2736",
        /* Minimap */
        "minimap.background": "#121f47",
        "minimap.findMatchHighlight": "#e3207b80",
        "minimap.selectionOccurrenceHighlight": "#d4b5a480",
        "minimap.errorHighlight": "#ff222080",
        "minimap.warningHighlight": "#ffdd3f80",
        "minimap.infoHighlight": "#d4b5a480",
        "minimap.foregroundOpacity": "#000000c0",
        "minimapSlider.background": "#1a3b8340",
        "minimapSlider.hoverBackground": "#1a3b8340",
        "minimapSlider.activeBackground": "#255cbd60",
        /* Scrollbar */
        "editorOverviewRuler.background": "#121f47",
        "scrollbar.shadow": "#0e152240",
        "scrollbarSlider.background": "#1a3b8340",
        "scrollbarSlider.hoverBackground": "#1a3b8340",
        "scrollbarSlider.activeBackground": "#255cbd60",
        /* Git decorations */
        "gitDecoration.addedResourceForeground": "#3cba3e",
        "gitDecoration.untrackedResourceForeground": "#3cba3e",
        "gitDecoration.modifiedResourceForeground": "#be6400",
        "gitDecoration.stageModifiedResourceForeground": "#be6400",
        "gitDecoration.deletedResourceForeground": "#d30000",
        "gitDecoration.stageDeletedResourceForeground": "#d30000",
        "gitDecoration.renamedResourceForeground": "#4099ff",
        "gitDecoration.ignoredResourceForeground": "#93776e",
        "gitDecoration.conflictingResourceForeground": "#d30000",
        "gitDecoration.submoduleResourceForeground": "#a044e0",
        /* TODO:
            - breadcrumb dropdown
        */
    },
    /* Syntax
    --------------------------------------------------------------------------*/
    "tokenColors": [
        {
            "name": "Comment",
            "scope": [
                "comment",
                "comment text",
                "punctuation.definition.comment",
                "string.comment",
                "string.quoted.docstring.multi.python",
                "string.quoted.docstring.multi.python punctuation.definition.string.begin.python",
                "string.quoted.docstring.multi.python punctuation.definition.string.end.python",
                "text.cancelled",
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#93776e"
            }
        },
        {
            "name": "Variables",
            "scope": [
                "variable",
                "string constant.other.placeholder",
            ],
            "settings": {
                "foreground": "#0b9684"
            }
        },
        {
            "name": "Keyword, Storage",
            "scope": [
                "keyword",
                "keyword.control",
                "keyword.other",
                "keyword.other.template",
                "keyword.other.substitution",
                "storage.type",
                "storage.modifier",
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#3cba3e"
            }
        },
        {
            "name": "Operator, Punctuation",
            "scope": [
                "punctuation",
                "punctuation.definition.tag",
                "punctuation.separator.inheritance.php",
                "punctuation.definition.tag.html",
                "punctuation.definition.tag.begin.html",
                "punctuation.definition.tag.end.html",
                "punctuation.section.embedded",
                "meta.tag",
            ],
            "settings": {
                "foreground": "#3cba3e"
            }
        },
        {
            "name": "Function, Special Method",
            "scope": [
                "entity.name.function",
                "meta.function-call",
                "variable.function",
                "support.function",
                "keyword.other.special-method",
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#3fd5b9"
            }
        },
        {
            "name": "Parameters, Arguments",
            "scope": [
                "variable.parameter",
                "meta.parameters",
                "meta.function-call.arguments",
            ],
            "settings": {
                "fontStyle": "",
                "foreground": "#0b9684"
            }
        },
        /* Tag (e.g. YAML keys) */
        {
            "name": "Tag",
            "scope": [
                "entity.name.tag",
                "meta.tag.sgml",
                "markup.deleted.git_gutter"
            ],
            "settings": {
                "foreground": "#0b9684"
            }
        },
        {
            "name": "Block Level Variables",
            "scope": [
                "meta.block variable.other"
            ],
            "settings": {
                "foreground": "#0b9684"
            }
        },
        {
            "name": "Other Variable, String Link",
            "scope": [
                "support.other.variable",
                "string.other.link"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#ffdd3f"
            }
        },
        {
            "name": "Number, Unit",
            "scope": [
                "constant.numeric",
                "keyword.other.unit",
            ],
            "settings": {
                "foreground": "#ff443e"
            }
        },
        {
            "name": "Constant",
            "scope": [
                "constant.language",
                "support.meta",
            ],
            "settings": {
                "foreground": "#ff2220"
            }
        },
        {
            "name": "String quotes",
            "scope": [
                "storage.type.string",
                "punctuation.definition.string",
                "punctuation.definition.string string",
            ],
            "settings": {
                "foreground": "#ffc155",
            }
        },
        {
            "name": "String, Symbols, Inherited Class",
            "scope": [
                "string",
                "constant.other.symbol",
                "constant.other.key",
                "entity.other.inherited-class",
                "markup.inserted.git_gutter",
                "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
            ],
            "settings": {
                "foreground": "#ffa321"
            }
        },
        {
            "name": "Types",
            "scope": [
                "support.type",
                "support.other.namespace.use.php",
                "meta.use.php",
                "support.other.namespace.php",
                "markup.changed.git_gutter",
                "support.type.sys-types"
            ],
            "settings": {
                "foreground": "#e3207b"
            }
        },
        {
            "name": "Class, Entity",
            "scope": [
                "entity.name",
                "meta.class",
                "support.class",
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#3fd5b9"
            }
        },
        {
            "name": "CSS Class and Support",
            "scope": [
                "source.css support.type.property-name",
                "source.sass support.type.property-name",
                "source.scss support.type.property-name",
                "source.less support.type.property-name",
                "source.stylus support.type.property-name",
                "source.postcss support.type.property-name"
            ],
            "settings": {
                "foreground": "#ff00ff"
            }
        },
        {
            "name": "Sub-methods",
            "scope": [
                "entity.name.module.js",
                "variable.import.parameter.js",
                "variable.other.class.js"
            ],
            "settings": {
                "foreground": "#0b9684"
            }
        },
        {
            "name": "Language methods",
            "scope": [
                "variable.language"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#0b9684"
            }
        },
        {
            "name": "entity.name.method.js",
            "scope": [
                "entity.name.method.js"
            ],
            "settings": {
                "foreground": "#0b9684"
            }
        },
        {
            "name": "meta.method.js",
            "scope": [
                "meta.class-method.js entity.name.function.js",
                "variable.function.constructor"
            ],
            "settings": {
                "foreground": "#3fd5b9"
            }
        },
        {
            "name": "Regular Expressions",
            "scope": [
                "string.regexp"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#ff2220"
            }
        },
        {
            "name": "Escape Characters",
            "scope": [
                "constant.character",
                "constant.escape",
                "constant.character.escape"
            ],
            "settings": {
                "fontStyle": "bold",
                "foreground": "#ffdd3f"
            }
        },
        {
            "name": "URL",
            "scope": [
                "*url*",
                "*link*",
                "*uri*"
            ],
            "settings": {
                "fontStyle": "underline"
            }
        },
        {
            "name": "Decorators",
            "scope": [
                "tag.decorator.js entity.name.tag.js",
                "tag.decorator.js punctuation.definition.tag.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#ff00ff"
            }
        },
        {
            "name": "ES7 Bind Operator",
            "scope": [
                "source.js constant.other.object.key.js string.unquoted.label.js"
            ],
            "settings": {
                "fontStyle": "italic",
                "foreground": "#3cba3e"
            }
        },
        {
            "name": "JSON Key - Level 0",
            "scope": [
                "source.json meta.structure.dictionary.json support.type.property-name.json"
            ],
            "settings": {
                "foreground": "#0b9684"
            }
        },
        {
